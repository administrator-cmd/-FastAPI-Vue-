# ============================================
# FastAPI Blog 系统 - 环境变量配置模板
# ============================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 修改对应的配置值
# 3. .env 文件不要提交到 Git
# ============================================

# ===== 数据库配置 =====
DATABASE_URL=sqlite+aiosqlite:///./blog_v4.db

# ===== JWT 认证配置 =====
# 生产环境必须使用强随机密钥（建议使用至少32位随机字符串）
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== AI API 配置（智能问答功能）=====
# AI API 密钥（从服务商获取）
AI_API_KEY=sk-your-api-key-here

# AI API 地址（OpenAI 格式）
AI_BASE_URL=https://api.openai.com/v1/chat/completions

# AI 模型名称
AI_MODEL=gpt-3.5-turbo

# ===== 其他可选配置 =====
# 如需使用其他 AI 服务商，修改以上 URL 和 Model 即可
# 示例（Azure OpenAI）：
# AI_API_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment/chat/completions?api-version=2023-05-15
# AI_MODEL=gpt-35-turbo
